# Database MySQL (Laravel backend)
# Jangan gunakan tanda kutip pada nilai (misal: DB_PASSWORD=mypass, BUKAN DB_PASSWORD='mypass')

# Host database. Sesuaikan dengan environment:
#   - Native / lokal              : 127.0.0.1  atau  localhost
#   - Docker bridge + DB remote   : IP server database (misal: 192.168.1.100)
#   - Docker host network         : 127.0.0.1  (container share network host)
#   - Docker bridge + DB di host  : host.docker.internal  (hanya jika MySQL bind 0.0.0.0)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=notifwa
DB_USERNAME=root
DB_PASSWORD=secret

WA_SECRET_TOKEN=your_secret_token_here